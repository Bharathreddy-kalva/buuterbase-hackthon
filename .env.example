# Butterbase - backend + AI gateway
BUTTERBASE_URL=https://api.butterbase.ai
BUTTERBASE_API_KEY=your-butterbase-api-key
BUTTERBASE_PROJECT_ID=your-butterbase-project-id
BUTTERBASE_AI_URL=https://api.butterbase.ai/v1/ai
BUTTERBASE_AI_KEY=your-butterbase-api-key

# EverOS models via the Butterbase AI gateway (chat/embeddings/rerank)
EVEROS_LLM__API_KEY=your-butterbase-api-key
EVEROS_LLM__MODEL=anthropic/claude-sonnet-4.6
EVEROS_LLM__BASE_URL=https://api.butterbase.ai/v1/ai
EVEROS_MULTIMODAL__API_KEY=your-butterbase-api-key
EVEROS_MULTIMODAL__MODEL=anthropic/claude-sonnet-4.6
EVEROS_EMBEDDING__API_KEY=your-butterbase-api-key
EVEROS_EMBEDDING__MODEL=amazon/amazon.titan-embed-text-v2:0
EVEROS_EMBEDDING__BASE_URL=https://api.butterbase.ai/v1/ai
EVEROS_RERANK__API_KEY=your-butterbase-api-key
EVEROS_RERANK__MODEL=amazon/amazon.titan-embed-text-v2:0
EVEROS_RERANK__BASE_URL=https://api.butterbase.ai/v1/ai

# EverMind Cloud - long-term agent memory
EVERMIND_API_KEY=your-evermind-api-key
EVERMIND_BASE_URL=https://api.evermind.ai

# Photon iMessage (get from app.photon.codes)
PHOTON_PROJECT_ID=your-photon-project-id
PHOTON_PROJECT_SECRET=your-photon-project-secret
PHOTON_WEBHOOK_SECRET=your-photon-webhook-secret
ALERT_IMESSAGE_NUMBER=+1XXXXXXXXXX

# Gmail inbox listener (autonomous email intake)
# Use a 16-digit Gmail App Password, NOT your normal login password.
# Enable IMAP in Gmail settings; create an App Password under
# Google Account -> Security -> App passwords.
EMAIL_HOST=imap.gmail.com
EMAIL_PORT=993
EMAIL_USER=your-fleetmind-gmail@gmail.com
EMAIL_PASSWORD=your-16-digit-app-password
EMAIL_CHECK_INTERVAL=15

# ngrok public URL exposing this server for Photon webhooks (see setup/ngrok_setup.md)
NGROK_URL=https://your-ngrok-url.ngrok.io

# App
PORT=8000
ENV=development
